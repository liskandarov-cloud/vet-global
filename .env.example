# ============================================================
# VetGlobal — root environment for docker-compose
# Copy to `.env` and adjust before `docker compose up`.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=vetglobal
POSTGRES_PASSWORD=vetglobal_dev_pwd
POSTGRES_DB=vetglobal
POSTGRES_PORT=5432

# --- Backend (NestJS) ---
BACKEND_PORT=8000
# DATABASE_URL is assembled inside compose from the POSTGRES_* vars.
JWT_SECRET=change-me-in-production-please-32chars-min
JWT_EXPIRES_IN=7d
# Platform commission percentage charged to sellers (10-12% per SRS)
PLATFORM_COMMISSION_PERCENT=12
# VetPoints: earn rate (% of order) and max spend (% of next order)
VETPOINTS_EARN_PERCENT=1
VETPOINTS_MAX_SPEND_PERCENT=10

# --- MinIO (S3-compatible object storage for images & PDF certificates) ---
MINIO_ROOT_USER=vetglobal
MINIO_ROOT_PASSWORD=vetglobal_dev_pwd
MINIO_BUCKET=vetglobal
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Public base URL the browser uses to fetch uploaded files
S3_PUBLIC_URL=http://localhost:9000

# --- SMS (Eskiz.uz) ---
# Leave ESKIZ_EMAIL empty for dev — SMS are logged to the backend console.
ESKIZ_BASE_URL=https://notify.eskiz.uz/api
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# --- Email (SMTP / SendGrid) ---
# Leave SMTP_HOST empty for dev — emails are logged to the backend console instead of sent.
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=<your-api-key>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=VetGlobal <no-reply@vetglobal.uz>

# --- Payments (Click / Payme / UZUM) ---
# mock = simulated checkout (no creds); live = real provider checkout URLs.
PAYMENTS_MODE=mock
PAYMENT_RETURN_URL=http://localhost:3000
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
# Payme "Key для системы" (merchant cabinet) — Basic-auth secret for the JSON-RPC endpoint
PAYME_KEY=
UZUM_MERCHANT_ID=

# --- Didox ЭДО (e-invoicing) ---
# mock = deterministic simulation (no creds); live = real Didox API.
DIDOX_MODE=mock
# Live only: test https://testapi3.didox.uz | prod https://api-partners.didox.uz
DIDOX_BASE_URL=https://testapi3.didox.uz
# Partner token issued by the Didox account manager (@Didox_account).
DIDOX_TOKEN=

# --- Telegram bot ---
# Get a token from @BotFather. Leave empty to disable the bot.
TELEGRAM_BOT_TOKEN=
# Optional: chat/group id that receives new-lead pings (e.g. admin's chat id).
TELEGRAM_ADMIN_CHAT_ID=

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
# Used by the bot to build product links back to the site.
FRONTEND_URL=http://localhost:3000
# Base URL of the API as seen from the browser
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Public site origin — used for sitemap.xml / canonical URLs
SITE_URL=http://localhost:3000

# --- Public deployment (docker-compose.deploy.yml + Caddy) ---
# DNS A-records for both must point to the server. Caddy issues TLS automatically.
APP_DOMAIN=vetglobal.example.com
FILES_DOMAIN=files.vetglobal.example.com

# --- Seed / default admin ---
ADMIN_EMAIL=admin@vetglobal.com
# Не оставляйте пароль по умолчанию на проде: seed заведёт админа с ним.
# Если не задать — seed сгенерирует случайный (войти будет нельзя, это намеренно).
ADMIN_PASSWORD=change-me-strong-password
